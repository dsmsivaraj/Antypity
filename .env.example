# Actypity example environment file
# Copy to .env and fill in values. Do NOT commit .env to source control.

# App
APP_NAME=Actypity Backend
APP_VERSION=2.0.0
DEBUG=true
SECRET_KEY=change-me-in-production
API_HOST=0.0.0.0
API_PORT=8002

# Storage
APP_STORAGE_BACKEND=postgres
APP_STORAGE_PATH=backend/data/executions.json

# Auth
AUTH_ENABLED=true
DEFAULT_ADMIN_KEY=
BOOTSTRAP_ADMIN_TOKEN=
INTERNAL_API_TOKEN=

# Postgres
# DATABASE_URL takes precedence over the below
DATABASE_URL=postgresql+psycopg:///actypity?host=/tmp&user=your_local_user
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=actypity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# LLaMA / Ollama (optional)
LLAMA_MODEL_PATH=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_MODELS=
RETRIEVAL_LOCAL_FALLBACK_ENABLED=true
RETRIEVAL_CANDIDATE_POOL_SIZE=12

# Figma (optional)
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=

# Google OAuth (Sign-In with Google) — required for /auth/google and ProfilePage
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials
# Add http://localhost:5173 to Authorized JavaScript origins
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini AI (optional — falls back to Ollama if unset)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Default model profile (optional — auto-selects best available provider if unset)
# Options: gemini-general, gemini-flash, azure-general, ollama-llama3, fallback-fast
#DEFAULT_MODEL_PROFILE=

# Trusted job sources (comma separated)
TRUSTED_JOB_SOURCES=linkedin,indeed,glassdoor,wellfound,naukri

# OpenAI (optional fallback for embeddings)
OPENAI_API_KEY=

# IMPORTANT: Do not put production secrets into source code. Use a secret manager or CI/CD secrets.
